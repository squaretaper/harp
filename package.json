{
  "name": "@dyad/harp",
  "version": "0.1.0",
  "description": "Human-Agent Relational Protocol — a relational memory layer for AI agents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./adapters": {
      "import": {
        "types": "./dist/adapters/index.d.ts",
        "default": "./dist/adapters/index.js"
      },
      "require": {
        "types": "./dist/adapters/index.d.cts",
        "default": "./dist/adapters/index.cjs"
      }
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "example:quickstart": "tsx examples/quickstart.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "protocol",
    "relationships",
    "typescript",
    "a2a",
    "mcp",
    "coordination",
    "harp",
    "relational-memory"
  ],
  "author": "Squaretaper",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/squaretaper/harp.git"
  },
  "homepage": "https://github.com/squaretaper/harp#readme",
  "bugs": {
    "url": "https://github.com/squaretaper/harp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
